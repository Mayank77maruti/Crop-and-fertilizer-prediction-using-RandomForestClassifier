import numpy as np
import pandas as pd
from sklearn.ensemble import RandomForestClassifier
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import accuracy_score, classification_report
from matplotlib import pyplot as plt
import matplotlib
matplotlib.rcParams["figure.figsize"] = (20, 10)

df1 = pd.read_csv("CropRecommendation_Fertilizer_Corrected.csv")
df1.head()

crop_encoder = LabelEncoder()
df1['label_encoded'] = crop_encoder.fit_transform(df1['label'])

soil_encoder = LabelEncoder()
df1['soil_type_encoded'] = soil_encoder.fit_transform(df1['soil_type'])

fertilizer_encoder = LabelEncoder()
df1['fertilizer_encoded'] = fertilizer_encoder.fit_transform(df1['Recommended_Fertilizer'])

print("Crop-to-Label Mapping:")
print(dict(zip(crop_encoder.classes_, crop_encoder.transform(crop_encoder.classes_))))

print("\nSoil Type Mapping:")
print(dict(zip(soil_encoder.classes_, soil_encoder.transform(soil_encoder.classes_))))

print("\nFertilizer Mapping:")
print(dict(zip(fertilizer_encoder.classes_, fertilizer_encoder.transform(fertilizer_encoder.classes_))))

features = ['N', 'P', 'K', 'temperature', 'humidity', 'ph', 'rainfall', 'soil_type_encoded']

X = df1[features]

y_crop = df1['label_encoded']

X_train, X_test, y_train, y_test = train_test_split(
    X, y_crop, test_size=0.15, random_state=42
)

rf_crop = RandomForestClassifier(n_estimators=100, random_state=42)
rf_crop.fit(X_train, y_train)

y_pred_crop = rf_crop.predict(X_test)
crop_accuracy = accuracy_score(y_test, y_pred_crop)

print(f"\n=== CROP MODEL ===")
print(f"Model Accuracy: {crop_accuracy * 100:.2f}%")
print("Classification Report:")
print(classification_report(y_test, y_pred_crop, target_names=crop_encoder.classes_))

y_fert = df1['fertilizer_encoded']

X_train_f, X_test_f, y_train_f, y_test_f = train_test_split(
    X, y_fert, test_size=0.15, random_state=42
)

rf_fert = RandomForestClassifier(n_estimators=100, random_state=42)
rf_fert.fit(X_train_f, y_train_f)

y_pred_fert = rf_fert.predict(X_test_f)
fert_accuracy = accuracy_score(y_test_f, y_pred_fert)

print(f"\n=== FERTILIZER MODEL ===")
print(f"Model Accuracy: {fert_accuracy * 100:.2f}%")
print("Classification Report:")
print(classification_report(y_test_f, y_pred_fert, target_names=fertilizer_encoder.classes_))

print("\n" + "="*45)
print("   CROP & FERTILIZER RECOMMENDATION SYSTEM")
print("="*45)

N           = float(input("Enter Nitrogen (N) value       : "))
P           = float(input("Enter Phosphorus (P) value     : "))
K           = float(input("Enter Potassium (K) value      : "))
temperature = float(input("Enter Temperature (°C)         : "))
humidity    = float(input("Enter Humidity (%)             : "))
ph          = float(input("Enter pH level                 : "))
rainfall    = float(input("Enter Rainfall (mm)            : "))

print(f"\nAvailable soil types: {list(soil_encoder.classes_)}")
soil_input = input("Enter Soil Type                : ").strip()

while soil_input not in soil_encoder.classes_:
    print(f"  ⚠ Invalid soil type. Choose from: {list(soil_encoder.classes_)}")
    soil_input = input("Enter Soil Type                : ").strip()

soil_encoded = soil_encoder.transform([soil_input])[0]

new_data = pd.DataFrame(
    [[N, P, K, temperature, humidity, ph, rainfall, soil_encoded]],
    columns=features
)

predicted_crop_label  = rf_crop.predict(new_data)
predicted_crop        = crop_encoder.inverse_transform(predicted_crop_label)

predicted_fert_label  = rf_fert.predict(new_data)
predicted_fert_ml     = fertilizer_encoder.inverse_transform(predicted_fert_label)


print("\n" + "="*45)
print("           PREDICTION RESULTS")
print("="*45)
print(f"  🌾 Recommended Crop       : {predicted_crop[0]}")
print(f"  🧪 Recommended Fertilizer : {predicted_fert_ml[0]}")
print("="*45)
